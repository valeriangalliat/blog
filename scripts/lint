#!/bin/sh -e
#
# Ensures that date and title match between actual articles and
# `index.md` and `posts.md` listings.
#

process() {
    file=$1; shift
    passthrough=false

    cat "$file" | while IFS= read line; do
        if "$passthrough"; then
            echo "$line"
            continue
        fi

        if [ "$line" = "## Pages" ]; then
            passthrough=true
        fi

        if ! echo "$line" | grep -q '^* .*</small>$'; then
            echo "$line"
            continue
        fi

        path=$(echo "$line" | sed 's/^.*](//;s/).*//')

        if ! [ -f "$path" ]; then
            echo "$line"
            continue
        fi

        # Only lint post links (in YYYY/MM/ or similar directories)
        if ! echo "$path" | grep -qE '^[0-9]{4}/'; then
            echo "$line"
            continue
        fi

        head=$(grep -m1 -A4 '^# ' "$path")
        title=$(echo "$head" | head -1 | sed 's/^# //')
        date=$((echo "$head" && echo) | grep -B1 '^$' | head -1)

        # Only keep the date part before " |" if there's an update annotation
        date=$(echo "$date" | sed 's/ |.*//')

        # Special case for "now page"
        if [[ "$date" =~ ^\*\* ]]; then
            date=$(echo "$date" | cut -d'*' -f3)
        fi

        expected="* [$title]($path) <small>$date</small>"

        if [ "$line" != "$expected" ]; then
            echo "Mismatch in $file" >&2
            echo "  Actual: $line" >&2
            echo "  Expected: $expected" >&2
            echo "  Fixing..." >&2
        fi

        echo "$expected"
    done > "$file.new"

    mv "$file.new" "$file"
}

process index.md
process posts.md
